---
const links = [
  { label: { sl: 'Domov', en: 'Home' }, href: '/' },
  { label: { sl: 'Apartma', en: 'Apartment' }, href: '/apartment' },
  { label: { sl: 'Galerija', en: 'Gallery' }, href: '/gallery' },
  { label: { sl: 'Cenik', en: 'Pricing' }, href: '/pricing' },
  { label: { sl: 'Aktivnosti', en: 'Activities' }, href: '/activities' },
  { label: { sl: 'Kontakt', en: 'Contact' }, href: '/contact' },
];

const amenities = [
  { sl: 'Brezplačen WiFi', en: 'Free WiFi' },
  { sl: 'Brezplačen parking', en: 'Free parking' },
  { sl: 'Klima', en: 'Air conditioning' },
  { sl: 'Živali dovoljene', en: 'Pets allowed' },
];
---

<footer class="bg-primary text-white" id="site-footer">
  <!-- Main Footer -->
  <div class="container-site py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block font-display text-2xl font-bold text-white mb-4 hover:text-accent transition-colors duration-200">
          River Kolpa
        </a>
        <p class="text-white/60 text-sm leading-relaxed mb-6" data-sl="Prenovljena tradicionalna počitniška hiša v mirni vasi Griblje, le 500m od reke Kolpe v Beli krajini." data-en="Renovated traditional holiday home in the quiet village of Griblje, just 500m from the Kolpa River in White Carniola.">
          Prenovljena tradicionalna počitniška hiša v mirni vasi Griblje, le 500m od reke Kolpe v Beli krajini.
        </p>
        <!-- Social Proof -->
        <div class="flex items-center gap-3">
          <div class="flex items-center gap-2 bg-white/10 px-3 py-2 rounded-full">
            <span class="text-accent text-lg">★</span>
            <span class="text-white font-bold text-sm">9.8</span>
          </div>
          <span class="text-white/50 text-xs" data-sl="Booking.com" data-en="Booking.com">Booking.com</span>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-display text-lg font-semibold text-white mb-5" data-sl="Navigacija" data-en="Navigation">Navigacija</h3>
        <nav class="space-y-3">
          {links.map(link => (
            <a
              href={link.href}
              class="block text-white/60 hover:text-accent text-sm transition-colors duration-200 cursor-pointer"
              data-sl={link.label.sl}
              data-en={link.label.en}
            >
              {link.label.sl}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="font-display text-lg font-semibold text-white mb-5" data-sl="Kontakt" data-en="Contact">Kontakt</h3>
        <div class="space-y-4">
          <a href="mailto:majda.pezdirc@gmail.com" class="flex items-start gap-3 text-white/60 hover:text-accent text-sm transition-colors duration-200 cursor-pointer group">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0 group-hover:text-accent transition-colors"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <span>majda.pezdirc@gmail.com</span>
          </a>
          <a href="tel:+38640858732" class="flex items-start gap-3 text-white/60 hover:text-accent text-sm transition-colors duration-200 cursor-pointer group">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0 group-hover:text-accent transition-colors"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>+386 40 858 732</span>
          </a>
          <a href="https://wa.me/38640858732" target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 text-white/60 hover:text-accent text-sm transition-colors duration-200 cursor-pointer group">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0 group-hover:text-accent transition-colors"><circle cx="12" cy="12" r="10"/><path d="m16 16-1.5-1.5a4.5 4.5 0 0 0-3.2-1.3c-1.2 0-2.3.5-3.2 1.3L6.5 16"/><path d="M9.5 10.5V9a2.5 2.5 0 0 1 5 0v1.5"/></svg>
            <span>WhatsApp</span>
          </a>
          <div class="flex items-start gap-3 text-white/60 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span data-sl="Griblje, Bela krajina, Slovenija" data-en="Griblje, White Carniola, Slovenia">Griblje, Bela krajina, Slovenija</span>
          </div>
        </div>
      </div>

      <!-- Amenities -->
      <div>
        <h3 class="font-display text-lg font-semibold text-white mb-5" data-sl="Ugodnosti" data-en="Amenities">Ugodnosti</h3>
        <ul class="space-y-3">
          {amenities.map(a => (
            <li class="flex items-center gap-2 text-white/60 text-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span>
              <span data-sl={a.sl} data-en={a.en}>{a.sl}</span>
            </li>
          ))}
        </ul>

        <!-- Booking CTA -->
        <a
          href="https://www.booking.com/hotel/si/holiday-house-kolpa.html"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block mt-6 bg-accent text-primary px-6 py-3 rounded-full font-bold text-sm hover:bg-accent-light hover:shadow-lg hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 cursor-pointer"
        >
          <span data-sl="Rezerviraj zdaj" data-en="Book now">Rezerviraj zdaj</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="container-site py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/40 text-xs" data-sl="© 2026 River Kolpa Apartments. Vse pravice pridržane." data-en="© 2026 River Kolpa Apartments. All rights reserved.">
        © 2026 River Kolpa Apartments. Vse pravice pridržane.
      </p>
      <div class="flex items-center gap-6">
        <a href="/contact" class="text-white/40 hover:text-white/70 text-xs transition-colors duration-200 cursor-pointer" data-sl="Zasebnost" data-en="Privacy">
          <span data-sl="Zasebnost" data-en="Privacy">Zasebnost</span>
        </a>
        <a href="/contact" class="text-white/40 hover:text-white/70 text-xs transition-colors duration-200 cursor-pointer" data-sl="Pogoji" data-en="Terms">
          <span data-sl="Pogoji" data-en="Terms">Pogoji</span>
        </a>
      </div>
    </div>
  </div>
</footer>
