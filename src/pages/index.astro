---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import Icon from '../components/Icon.astro';
import WeatherWidget from '../components/WeatherWidget.astro';

const heroImg = "/images/hero-outdoor-kitchen.png";
const bookingUrl = "https://www.booking.com/hotel/si/holiday-house-kolpa.html";

const PROPERTY_IMAGES = {
  terrace: "/images/terrace.png",
  outdoorKitchen: "/images/outdoor-kitchen.png",
  bathroom: "/images/bathroom.png",
  hallway: "/images/hallway.png",
  garden: "/images/garden-relaxation.png",
};

const galleryImages = [
  { src: "/images/terrace.png", alt: "Terasa" },
  { src: "/images/bedroom1.png", alt: "Glavna spalnica" },
  { src: "/images/kitchen.png", alt: "Moderna kuhinja" },
  { src: "/images/livingroom.png", alt: "Dnevna soba" },
  { src: "/images/view.png", alt: "Razgled na Belo krajino" },
  { src: "/images/bedroom2.png", alt: "Druga spalnica" },
  { src: "/images/bedroom3.png", alt: "Tretja spalnica" },
  { src: "/images/stairs.png", alt: "Stopnice in hodnik" },
  { src: "/images/balcony.png", alt: "Balkon" },
];

const amenities = [
  { icon: "waves", label: { sl: "500m do reke", en: "500m to river" } },
  { icon: "car", label: { sl: "Brezplačen parking", en: "Free parking" } },
  { icon: "wifi", label: { sl: "Brezplačen Wi-Fi", en: "Free Wi-Fi" } },
  { icon: "snowflake", label: { sl: "Klima", en: "Air conditioning" } },
  { icon: "tv", label: { sl: "Smart TV", en: "Smart TV" } },
  { icon: "coffee", label: { sl: "Kavni aparat", en: "Coffee machine" } },
  { icon: "utensils", label: { sl: "Polna kuhinja", en: "Full kitchen" } },
  { icon: "flame", label: { sl: "Žar", en: "BBQ grill" } },
  { icon: "trees", label: { sl: "Zasebni vrt", en: "Private garden" } },
  { icon: "dog", label: { sl: "Živali dovoljene", en: "Pets allowed" } },
  { icon: "baby", label: { sl: "Za družine", en: "Family friendly" } },
  { icon: "shower", label: { sl: "Zasebna kopalnica", en: "Private bathroom" } },
];

const activities = [
  { icon: "waves", cat: { sl: "VODA", en: "WATER" }, title: { sl: "Kajakaštvo in kanu", en: "Kayaking & Canoe" }, desc: { sl: "Veslarite po kristalno čisti Kolpi", en: "Paddle on crystal clear Kolpa" } },
  { icon: "bike", cat: { sl: "KOLESARJENJE", en: "CYCLING" }, title: { sl: "Ob reki na kolesu", en: "Riverside cycling" }, desc: { sl: "GPX poti za vse ravni", en: "GPX routes for all levels" } },
  { icon: "mountain", cat: { sl: "POHODNIŠTVO", en: "HIKING" }, title: { sl: "Gozdne poti", en: "Forest trails" }, desc: { sl: "Označene poti skozi Belo krajino", en: "Marked trails through White Carniola" } },
  { icon: "wheat", cat: { sl: "LOKALNO", en: "LOCAL" }, title: { sl: "Domači pridelki", en: "Local produce" }, desc: { sl: "Neposredno od kmetov", en: "Direct from local farmers" } },
];

const reviews = [
  { text: { sl: "Zelo smo bili zadovoljni z nastanitvijo, res je tako lepo kot na slikah. Gostiteljica zelo prijazna.", en: "Very satisfied with the accommodation, truly as beautiful as in the pictures. Hostess very friendly." }, name: "Mojca", country: "🇸🇮", platform: "Booking.com" },
  { text: { sl: "Skrit biser ob reki Kolpi. Apartma je odlično opremljen, vrt čudovit za večere ob žaru.", en: "Hidden gem by the Kolpa river. Apartment excellently equipped, garden beautiful for BBQ evenings." }, name: "Thomas", country: "🇦🇹", platform: "Booking.com" },
  { text: { sl: "Ideala lokacija za družine. Kolpa je topla in varna za kopanje. Absolutno priporočamo!", en: "Ideal location for families. Kolpa is warm and safe for swimming. Absolutely recommended!" }, name: "Družina Müller", country: "🇩🇪", platform: "Booking.com" },
];
---

<head>
  <meta charset="UTF-8" />
  <meta name="description" content="Premium apartmaji River Kolpa v Beli krajini. Sprostitev ob reki Kolpi, zunanji bazen, žar in neokrnjena narava. Rezervirajte svoj oddih zdaj!" />
  <meta name="keywords" content="apartmaji Bela krajina, River Kolpa, počitnice Slovenija, Kolpa, najem počitniške hiše, wellness, narava" />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://riverkolpa.si/" />
  <meta property="og:title" content="River Kolpa Apartments | Premium Oddih v Beli Krajini" />
  <meta property="og:description" content="Doživite neokrnjeno naravo Bele krajine. Luksuzni apartmaji ob reki Kolpi z vsemi ugodnostmi." />
  <meta property="og:image" content="/images/terrace.png" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content="https://riverkolpa.si/" />
  <meta property="twitter:title" content="River Kolpa Apartments | Premium Oddih v Beli Krajini" />
  <meta property="twitter:description" content="Doživite neokrnjeno naravo Bele krajine. Luksuzni apartmaji ob reki Kolpi z vsemi ugodnostmi." />
  <meta property="twitter:image" content="/images/terrace.png" />

  <!-- Structured Data (JSON-LD) for Google -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ApartmentComplex",
      "name": "River Kolpa Apartments",
      "description": "Premium apartmaji ob reki Kolpi v Beli krajini.",
      "url": "https://riverkolpa.si/",
      "telephone": "+38640858732",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Griblje",
        "addressLocality": "Črnomelj",
        "postalCode": "8340",
        "addressCountry": "SI"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 45.54,
        "longitude": 15.21
      },
      "image": "/images/terrace.png",
      "priceRange": "€€",
      "starRating": {
        "@type": "Rating",
        "ratingValue": "4.8",
        "bestRating": "5"
      },
      "amenityFeature": [
        { "@type": "LocationFeatureSpecification", "name": "Free WiFi" },
        { "@type": "LocationFeatureSpecification", "name": "Air Conditioning" },
        { "@type": "LocationFeatureSpecification", "name": "BBQ Grill" },
        { "@type": "LocationFeatureSpecification", "name": "Garden" }
      ]
    }
  </script>
</head>

<Layout title="River Kolpa Apartments | Premium Apartmaji Bela Krajina">
  <Header />

  <main id="main-content">
    {/* HERO */}
    <section class="relative h-screen min-h-[700px] overflow-hidden flex items-center justify-center">
      <div class="absolute inset-0">
        <img src={heroImg} alt="Zunanja kuhinja z razgledom na vinograde in hribe" class="w-full h-full object-cover" width={1920} height={1080} />
        <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black/60" />
      </div>

      <div class="relative z-10 text-center px-4 max-w-4xl mx-auto" data-aos="fade-up" data-aos-duration="1000">
        <p class="text-white/60 uppercase tracking-[0.3em] text-xs md:text-sm mb-6 font-medium">
          <span data-sl="Bela krajina, Slovenija" data-en="White Carniola, Slovenia">Bela krajina, Slovenija</span>
        </p>
        <h1 class="font-display text-6xl md:text-7xl lg:text-8xl text-white font-semibold mb-6 leading-[1.05]">
          <span data-sl="Vaš rečni" data-en="Your riverside">Vaš rečni</span><br />
          <span class="italic font-accent font-normal text-accent-light">pobeg</span>
        </h1>
        <p class="font-accent italic text-white/70 text-xl md:text-2xl mb-12 max-w-xl mx-auto">
          <span data-sl="Kjer Kolpa šepeta in gozd diha" data-en="Where Kolpa whispers and forest breathes">Kjer Kolpa šepeta in gozd diha</span>
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <a href="#apartment" class="btn-primary">
            <span data-sl="Raziščite apartma" data-en="Explore apartment">Raziščite apartma</span>
          </a>
          <a href={bookingUrl} target="_blank" rel="noopener noreferrer" class="btn-outline">
            <span data-sl="Preverite razpoložljivost" data-en="Check availability">Preverite razpoložljivost</span>
          </a>

          {/* VOICE SEARCH BUTTON (2026 Feature) */}
          <button id="voice-btn" class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-md border border-white/30 flex items-center justify-center hover:bg-white/30 transition-all active:scale-95 cursor-pointer" aria-label="Voice search">
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
          </button>
        </div>

        {/* Voice Status Message */}
        <div id="voice-status" class="hidden mt-4 text-white/80 text-sm bg-black/20 px-4 py-2 rounded-full inline-block backdrop-blur-sm">
          Poslušam...
        </div>
      </div>

      {/* Booking Badge */}
      <div class="absolute top-28 right-6 md:right-16 z-10 glass-dark rounded-2xl px-6 py-5 hidden md:flex items-center gap-4 animate-float cursor-pointer" data-aos="fade-left" data-aos-delay="400">
        <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-accent"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <div>
          <div class="text-white text-lg font-bold">9.8 / 10</div>
          <div class="text-white/50 text-xs uppercase tracking-wider">Booking.com</div>
        </div>
      </div>

      {/* Scroll Indicator */}
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-3" data-aos="fade-up" data-aos-delay="800">
        <span class="text-white/40 text-xs uppercase tracking-[0.2em]"><span data-sl="Pomik" data-en="Scroll">Pomik</span></span>
        <div class="w-6 h-10 border-2 border-white/30 rounded-full flex justify-center p-1">
          <div class="w-1.5 h-3 bg-white/60 rounded-full animate-bounce" />
        </div>
      </div>
    </section>

    {/* SOCIAL PROOF BAR */}
    <div class="bg-primary text-white/80 py-4 border-b border-white/5">
      <div class="container-site flex items-center justify-center gap-8 text-sm px-6">
        <span class="flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-accent"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> <span data-sl="Odlično ocenjen" data-en="Excellent rating">Odlično ocenjen</span></span>
        <span class="hidden sm:block text-white/20">|</span>
        <span class="hidden sm:flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-accent"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> <span data-sl="5-zvezdične ocene" data-en="5-star reviews">5-zvezdične ocene</span></span>
        <span class="hidden md:block text-white/20">|</span>
        <span class="hidden md:flex items-center gap-2"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M2 12c1.5-2 3.5-2 5 0s3.5 2 5 0 3.5-2 5 0 3.5 2 5 0"/><path d="M2 18c1.5-2 3.5-2 5 0s3.5 2 5 0 3.5-2 5 0 3.5 2 5 0"/><path d="M2 6c1.5-2 3.5-2 5 0s3.5 2 5 0 3.5-2 5 0 3.5 2 5 0"/></svg> <span data-sl="500m do Kolpe" data-en="500m to Kolpa">500m do Kolpe</span></span>
      </div>
    </div>

    {/* WEATHER WIDGET - LIVE DATA */}
    <div class="py-6 bg-background border-b border-border">
      <WeatherWidget />
    </div>

    {/* STATS */}
    <section class="section-padding bg-surface">
      <div class="container-site grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
        {[
          { val: "7", icon: "users", label: { sl: "Gostov", en: "Guests" } },
          { val: "2", icon: "bed", label: { sl: "Spalnici", en: "Bedrooms" } },
          { val: "10", suffix: " min", icon: "footprints", label: { sl: "do reke", en: "to river" } },
          { val: "500", suffix: "m", icon: "umbrella", label: { sl: "do plaže", en: "to beach" } },
        ].map((s, i) => (
          <div class="text-center group cursor-pointer" data-aos="fade-up" data-aos-delay={i * 100}>
            <div class="text-primary/60 mb-4 flex justify-center group-hover:text-primary transition-colors duration-300">
              <Icon name={s.icon} />
            </div>
            <div class="font-display text-4xl md:text-5xl font-bold text-primary mb-2">
              {s.val}{s.suffix || ""}
            </div>
            <div class="text-text-muted text-sm font-medium uppercase tracking-wider">
              <span data-sl={s.label.sl} data-en={s.label.en}>{s.label.sl}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* PROPERTY INTRO */}
    <section id="apartment" class="section-padding bg-background">
      <div class="container-site grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="rounded-3xl overflow-hidden shadow-2xl relative group" data-aos="fade-right">
          <img src={PROPERTY_IMAGES.terrace} alt="Terasa" class="w-full h-full object-cover aspect-[4/3] group-hover:scale-[1.03] transition-transform duration-700" width={800} height={600} />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
        </div>
        <div data-aos="fade-left">
          <p class="text-accent uppercase tracking-[0.25em] text-xs font-bold mb-4">
            <span data-sl="Vaš dom v Beli krajini" data-en="Your home in White Carniola">Vaš dom v Beli krajini</span>
          </p>
          <h2 class="font-display text-4xl md:text-5xl text-primary mb-6 leading-tight">
            <span data-sl="Prenovljeno zatočišče za družine in pustolovce" data-en="Renovated retreat for families and adventurers">Prenovljeno zatočišče za družine in pustolovce</span>
          </h2>
          <div class="space-y-5 text-text-muted leading-[1.9] text-lg">
            <p>
              <span data-sl="V mirni vasi Griblje vas naša v celoti prenovljena tradicionalna počitniška hiša sprejme do 7 gostov z vsem udobjem doma." data-en="In the quiet village of Griblje, our fully renovated traditional holiday home welcomes up to 7 guests with all the comforts of home.">V mirni vasi Griblje vas naša v celoti prenovljena tradicionalna počitniška hiša sprejme do 7 gostov z vsem udobjem doma.</span>
            </p>
            <p>
              <span data-sl="Stopite na zasebno sončno teraso, prižgite žar v zunanji kuhinji ali se sprostite v visečem stolu sredi urejenega vrta." data-en="Step onto the private sunny terrace, light the BBQ in the outdoor kitchen, or relax in the hanging chair amidst the landscaped garden.">Stopite na zasebno sončno teraso, prižgite žar v zunanji kuhinji ali se sprostite v visečem stolu sredi urejenega vrta.</span>
            </p>
          </div>
          <a href="/apartment" class="inline-flex items-center gap-3 text-primary font-bold mt-8 group/link hover:gap-4 transition-all text-lg">
            <span data-sl="Oglejte si vse ugodnosti" data-en="View all amenities">Oglejte si vse ugodnosti</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover/link:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    {/* AMENITIES */}
    <section class="section-padding bg-surface">
      <div class="container-site">
        <div class="text-center mb-14" data-aos="fade-up">
          <p class="text-accent uppercase tracking-[0.25em] text-xs font-bold mb-3">
            <span data-sl="Popolnoma opremljeno" data-en="Fully equipped">Popolnoma opremljeno</span>
          </p>
          <h2 class="font-display text-4xl md:text-5xl text-primary">
            <span data-sl="Vse za popoln oddih" data-en="Everything for a perfect stay">Vse za popoln oddih</span>
          </h2>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
          {amenities.map((a, i) => (
            <div
              key={i}
              class="glass rounded-2xl p-6 flex flex-col items-center text-center gap-3 card-hover cursor-pointer"
              data-aos="zoom-in"
              data-aos-delay={i * 50}
            >
              <Icon name={a.icon} class="text-primary/70" />
              <span class="text-sm font-medium text-text">
                <span data-sl={a.label.sl} data-en={a.label.en}>{a.label.sl}</span>
              </span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* GARDEN & RELAXATION - NOVA SEKCIJA S TVOJO SLIKO */}
    <section class="section-padding bg-background overflow-hidden">
      <div class="container-site">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div data-aos="fade-right">
            <p class="text-accent uppercase tracking-[0.25em] text-xs font-bold mb-3">
              <span data-sl="Narava in mir" data-en="Nature and peace">Narava in mir</span>
            </p>
            <h2 class="font-display text-4xl md:text-5xl text-primary mb-6 leading-tight">
              <span data-sl="Vaš zasebni kotiček za sprostitev" data-en="Your private corner for relaxation">Vaš zasebni kotiček za sprostitev</span>
            </h2>
            <div class="space-y-5 text-text-muted leading-relaxed text-lg">
              <p>
                <span data-sl="Zbudite se v mirni Beli krajini in stopite naravnost na naš urejen, prostran vrt. Na voljo imate ležalnike za sončenje, zunanji žar za nepozabne večere in čudovit razgled na okoliško naravo." data-en="Wake up in quiet White Carniola and step directly onto our landscaped, spacious garden. Enjoy deck chairs for sunbathing, an outdoor grill for unforgettable evenings, and a wonderful view of the surrounding nature.">
                  Zbudite se v mirni Beli krajini in stopite naravnost na naš urejen, prostran vrt. Na voljo imate ležalnike za sončenje, zunanji žar za nepozabne večere in čudovit razgled na okoliško naravo.
                </span>
              </p>
              <p>
                <span data-sl="Popolnoma zasebno in mirno – idealno za branje knjige, jutranjo kavo ali igro z družino na svežem zraku." data-en="Completely private and quiet – ideal for reading a book, morning coffee, or playing with family in the fresh air.">
                  Popolnoma zasebno in mirno – idealno za branje knjige, jutranjo kavo ali igro z družino na svežem zraku.
                </span>
              </p>
            </div>
            <div class="mt-8 flex gap-4 flex-wrap">
               <div class="flex items-center gap-2 text-primary font-medium bg-primary/5 px-4 py-2 rounded-full">
                 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
                 <span data-sl="Urejen vrt" data-en="Landscaped garden">Urejen vrt</span>
               </div>
               <div class="flex items-center gap-2 text-primary font-medium bg-primary/5 px-4 py-2 rounded-full">
                 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
                 <span data-sl="Zunanji žar" data-en="Outdoor grill">Zunanji žar</span>
               </div>
               <div class="flex items-center gap-2 text-primary font-medium bg-primary/5 px-4 py-2 rounded-full">
                 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>
                 <span data-sl="Razgled" data-en="View">Razgled</span>
               </div>
            </div>
          </div>
          <div class="rounded-3xl overflow-hidden shadow-2xl relative group" data-aos="fade-left">
            <img
              src="/images/garden-relaxation.png"
              alt="Sprostitev na vrtu ob pogledu na Belo krajino"
              class="rounded-3xl shadow-2xl group-hover:scale-[1.03] transition-transform duration-700 w-full h-auto"
              width={1200}
              height={800}
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-3xl" />
          </div>
        </div>
      </div>
    </section>

    {/* BENTO GRID GALLERY */}
    <section id="gallery" class="section-padding bg-surface">
      <div class="container-site">
        <div class="text-center mb-14" data-aos="fade-up">
          <p class="text-accent uppercase tracking-[0.25em] text-xs font-bold mb-3">
            <span data-sl="Foto galerija" data-en="Photo Gallery">Foto galerija</span>
          </p>
          <h2 class="font-display text-4xl md:text-5xl text-primary">
