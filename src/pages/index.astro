      <div class="bg-white dark:bg-gray-800 rounded-3xl shadow-2xl max-w-md w-full p-8 relative transform transition-all" id="modal-content">
        <button id="close-modal" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 dark:text-gray-300 dark:hover:text-white text-2xl w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">&times;</button>
        
        <div class="text-center mb-6">
          <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-primary dark:text-white" data-sl="Rezerviraj termin" data-en="Book Your Stay">Rezerviraj termin</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm mt-1" data-sl="Izpolnite obrazec za povpraševanje." data-en="Fill out the form for inquiry.">Izpolnite obrazec za povpraševanje.</p>
        </div>
        
        <form class="space-y-4" onsubmit="event.preventDefault(); window.open('https://www.booking.com/hotel/si/holiday-house-kolpa.html', '_blank');">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1" data-sl="Prihod" data-en="Check-in">Prihod</label>
              <input type="date" class="w-full p-3 rounded-xl border-2 border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-white focus:border-primary focus:ring-0 transition-colors" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1" data-sl="Odhod" data-en="Check-out">Odhod</label>
              <input type="date" class="w-full p-3 rounded-xl border-2 border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-white focus:border-primary focus:ring-0 transition-colors" />
            </div>
          </div>
          
          <div>
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1" data-sl="Število gostov" data-en="Number of Guests">Število gostov</label>
            <select class="w-full p-3 rounded-xl border-2 border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-white focus:border-primary focus:ring-0 transition-colors">
              <option>1 oseba</option>
              <option selected>2 osebi</option>
              <option>3 osebe</option>
              <option>4 osebe</option>
              <option>5 oseb</option>
              <option>6 oseb</option>
              <option>7 oseb</option>
            </select>
          </div>
          
          <div>
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1" data-sl="Ime in priimek" data-en="Full Name">Ime in priimek</label>
            <input type="text" class="w-full p-3 rounded-xl border-2 border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-white focus:border-primary focus:ring-0 transition-colors" placeholder="Janez Novak" />
          </div>
          
          <div>
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1" data-sl="Email" data-en="Email">Email</label>
            <input type="email" class="w-full p-3 rounded-xl border-2 border-gray-200 dark:border-gray-600 dark:bg-gray-700 dark:text-white focus:border-primary focus:ring-0 transition-colors" placeholder="janez@example.com" />
          </div>
          
          <button type="submit" class="w-full bg-primary text-white py-4 rounded-xl font-bold text-lg hover:bg-primary-dark transition-all shadow-lg shadow-primary/30 hover:shadow-primary/50 transform hover:-translate-y-0.5" data-sl="Pošlji povpraševanje" data-en="Send Inquiry">
            Pošlji povpraševanje
          </button>
          
          <p class="text-center text-xs text-gray-400 dark:text-gray-500" data-sl="Prejeli boste odgovor v 24 urah." data-en="You will receive a response within 24 hours.">Prejeli boste odgovor v 24 urah.</p>
        </form>
      </div>
    </div>

    {/* GLOBAL STYLES FOR SMOOTH SCROLL AND ANIMATIONS */}
    <style>
      html {
        scroll-behavior: smooth;
      }
      @keyframes bounce-slow {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
      }
      .animate-bounce-slow {
        animation: bounce-slow 3s infinite ease-in-out;
      }
      @keyframes pulse-ring {
        0% { transform: scale(0.8); opacity: 1; }
        100% { transform: scale(1.3); opacity: 0; }
      }
      .voice-active::after {
        content: '';
        position: absolute;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: rgba(239, 68, 68, 0.5);
        animation: pulse-ring 1.5s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
      }
    </style>

    {/* SCRIPTS FOR 2026 FEATURES */}
    <script>
      // 1. MENU TOGGLE
      const menuToggle = document.getElementById('menu-toggle');
      const quickMenu = document.getElementById('quick-menu');
      
      menuToggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        quickMenu.classList.toggle('hidden');
        if (!quickMenu.classList.contains('hidden')) {
          quickMenu.style.transform = 'scale(1)';
          quickMenu.style.opacity = '1';
        } else {
          quickMenu.style.transform = 'scale(0.95)';
          quickMenu.style.opacity = '0';
        }
      });
      
      document.addEventListener('click', (e) => {
        if (!quickMenu.contains(e.target) && e.target !== menuToggle) {
          quickMenu.classList.add('hidden');
        }
      });

      // 2. DARK MODE FUNCTIONALITY
      const darkToggle = document.getElementById('dark-mode-toggle');
      const darkIcon = document.getElementById('dark-icon');
      let isDark = false;

      darkToggle?.addEventListener('click', () => {
        isDark = !isDark;
        document.documentElement.classList.toggle('dark');
        darkIcon.innerHTML = isDark ? '☀️' : '🌙';
        
        if (isDark) {
          document.body.style.backgroundColor = '#111827';
          document.body.style.color = '#f3f4f6';
          document.querySelectorAll('h1, h2, h3, h4, h5, h6').forEach(el => el.style.color = '#ffffff');
          document.querySelectorAll('.glass').forEach(el => {
             el.style.backgroundColor = 'rgba(255,255,255,0.05)';
             el.style.borderColor = 'rgba(255,255,255,0.1)';
          });
        } else {
          document.body.style.backgroundColor = '';
          document.body.style.color = '';
          document.querySelectorAll('h1, h2, h3, h4, h5, h6').forEach(el => el.style.color = '');
          document.querySelectorAll('.glass').forEach(el => {
             el.style.backgroundColor = '';
             el.style.borderColor = '';
          });
        }
        quickMenu.classList.add('hidden');
      });

      // 3. LANGUAGE SWITCHER
      const langBtn = document.getElementById('lang-toggle');
      let currentLang = 'sl';

      langBtn?.addEventListener('click', () => {
        currentLang = currentLang === 'sl' ? 'en' : 'sl';
        langBtn.querySelector('span').textContent = currentLang === 'sl' ? '🌍' : '🇸🇮';
        
        document.querySelectorAll('[data-sl][data-en]').forEach(el => {
           const text = el.getAttribute(`data-${currentLang}`);
           if (text) el.textContent = text;
        });
        quickMenu.classList.add('hidden');
      });

      // 4. VOICE SEARCH WITH VISUAL FEEDBACK
      const voiceBtn = document.getElementById('voice-btn');
      
      if (voiceBtn) {
        voiceBtn.addEventListener('click', () => {
          const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
          
          if (SpeechRecognition) {
            const recognition = new SpeechRecognition();
            recognition.lang = 'sl-SI';
            recognition.start();
            
            voiceBtn.classList.add('voice-active');
            voiceBtn.querySelector('span:last-child').textContent = 'Poslušam...';

            recognition.onresult = (event) => {
              const transcript = event.results[0][0].transcript;
              voiceBtn.classList.remove('voice-active');
              voiceBtn.querySelector('span:last-child').textContent = `Slišal: "${transcript}"`;
              setTimeout(() => {
                voiceBtn.querySelector('span:last-child').textContent = currentLang === 'sl' ? 'Glasovno iskanje' : 'Voice Search';
              }, 3000);
            };

            recognition.onerror = () => {
              voiceBtn.classList.remove('voice-active');
              voiceBtn.querySelector('span:last-child').textContent = 'Napaka';
            };
            
            recognition.onend = () => {
              voiceBtn.classList.remove('voice-active');
            };
          } else {
            alert('Vaš brskalnik ne podpira glasovnega iskanja.');
          }
          quickMenu.classList.add('hidden');
        });
      }

      // 5. BOOKING MODAL
      const bookNowBtn = document.getElementById('book-now-btn');
      const bookingModal = document.getElementById('booking-modal');
      const closeModal = document.getElementById('close-modal');
      const modalContent = document.getElementById('modal-content');

      bookNowBtn?.addEventListener('click', () => {
        bookingModal.classList.remove('hidden');
        bookingModal.style.display = 'flex';
        setTimeout(() => {
          modalContent.style.transform = 'scale(1)';
          modalContent.style.opacity = '1';
        }, 10);
        quickMenu.classList.add('hidden');
      });

      closeModal?.addEventListener('click', () => {
        modalContent.style.transform = 'scale(0.95)';
        modalContent.style.opacity = '0';
        setTimeout(() => {
          bookingModal.classList.add('hidden');
          bookingModal.style.display = 'none';
        }, 200);
      });

      bookingModal?.addEventListener('click', (e) => {
        if (e.target === bookingModal) {
          modalContent.style.transform = 'scale(0.95)';
          modalContent.style.opacity = '0';
          setTimeout(() => {
            bookingModal.classList.add('hidden');
            bookingModal.style.display = 'none';
          }, 200);
        }
      });
    </script>

    <!-- FAQ Section -->
    <FAQ />

    <Footer />
  </main>
</Layout>
