---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Stran ni najdena | River Kolpa Apartments" canonicalURL="https://riverkolpa.si/404">
  <Header />

  <main id="main-content" class="pt-20">
    <section class="min-h-[80vh] flex items-center justify-center bg-background">
      <div class="container-site text-center px-6 py-20">
        <!-- 404 Illustration -->
        <div class="mb-8 relative inline-block">
          <svg class="w-32 h-32 mx-auto text-primary/20" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m15 9-6 6"/>
            <path d="m9 9 6 6"/>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-6xl font-display font-bold text-primary">404</span>
          </div>
        </div>

        <h1 class="font-display text-4xl md:text-5xl text-primary mb-4" data-sl="Stran ni najdena" data-en="Page not found">
          Stran ni najdena
        </h1>
        <p class="text-text-muted text-lg mb-12 max-w-md mx-auto" data-sl="Ojoj! Strani, ki jo iščete, ne obstaja ali je bila premaknjena." data-en="Oops! The page you're looking for doesn't exist or has been moved.">
          Ojoj! Strani, ki jo iščete, ne obstaja ali je bila premaknjena.
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <a href="/" class="bg-primary text-white px-8 py-3 rounded-full font-medium hover:bg-primary-light hover:shadow-lg hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 cursor-pointer">
            <span data-sl="Nazaj domov" data-en="Back to home">Nazaj domov</span>
          </a>
          <a href="/apartment" class="border border-primary/30 text-primary px-8 py-3 rounded-full font-medium hover:bg-primary/5 transition-all duration-200 cursor-pointer">
            <span data-sl="Oglejte si apartma" data-en="View apartment">Oglejte si apartma</span>
          </a>
        </div>

        <!-- Helpful Links -->
        <div class="mt-16 max-w-lg mx-auto">
          <h2 class="font-display text-xl text-primary mb-6" data-sl="Priljubljene strani" data-en="Popular pages">Priljubljene strani</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-left">
            <a href="/apartment" class="flex items-center gap-3 p-4 rounded-xl bg-surface border border-border hover:shadow-md hover:border-accent/30 transition-all cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent flex-shrink-0"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
              <span class="text-sm font-medium text-primary" data-sl="Apartma" data-en="Apartment">Apartma</span>
            </a>
            <a href="/gallery" class="flex items-center gap-3 p-4 rounded-xl bg-surface border border-border hover:shadow-md hover:border-accent/30 transition-all cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent flex-shrink-0"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
              <span class="text-sm font-medium text-primary" data-sl="Galerija" data-en="Gallery">Galerija</span>
            </a>
            <a href="/pricing" class="flex items-center gap-3 p-4 rounded-xl bg-surface border border-border hover:shadow-md hover:border-accent/30 transition-all cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent flex-shrink-0"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              <span class="text-sm font-medium text-primary" data-sl="Cenik" data-en="Pricing">Cenik</span>
            </a>
            <a href="/contact" class="flex items-center gap-3 p-4 rounded-xl bg-surface border border-border hover:shadow-md hover:border-accent/30 transition-all cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent flex-shrink-0"><path d="M25 20a2 2 0 0 1-2 2h-2"/><path d="M13 15a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2v-1a2 2 0 0 1 2-2"/><path d="M14 7V4a1 1 0 0 0-1-1H6a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h2"/><path d="M20 7h-5"/><path d="M15 10h3.5a3.5 3.5 0 0 1 0 7H15"/></svg>
              <span class="text-sm font-medium text-primary" data-sl="Kontakt" data-en="Contact">Kontakt</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</Layout>
